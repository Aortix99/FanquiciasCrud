# Copia a .env y completa (no subas .env al repositorio).
# Uso tipico: Supabase u otro PostgreSQL remoto cuando no usas docker-compose db.

SPRING_DATASOURCE_URL=jdbc:postgresql://your-supabase-host:5432/postgres?sslmode=require
SPRING_DATASOURCE_USERNAME=postgres
SPRING_DATASOURCE_PASSWORD=your_password
